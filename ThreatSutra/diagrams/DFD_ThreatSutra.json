{
  "version": "2.6.2",
  "summary": {
    "title": "ThreatSutra",
    "owner": "Shabnam",
    "description": "AI-assisted requirement generation workflow for OWASP Cornucopia threat modeling sessions. The system accepts selected Cornucopia card IDs, retrieves related card data through the Cornucopia API, enriches context using vector search, and generates draft security requirements with LLM providers such as Gemini or Mistral. Generated outputs are reviewed through a mandatory human review gate before approved requirements are exported to Jira. The design focuses on loose API-based integration between Cornucopia, Threat Dragon, vector retrieval, LLM services, and external workflow systems.",
    "id": 0
  },
